---
import ToolLayout from '../layouts/ToolLayout.astro'
import Tabs from '../components/Tabs'
import ColorPicker from '../components/color/ColorPicker'
import PaletteGenerator from '../components/color/PaletteGenerator'
import SemanticPanel from '../components/color/SemanticPanel'
import ContrastPanel from '../components/color/ContrastPanel'
import CvdPanel from '../components/color/CvdPanel'
import ExportPanel from '../components/export/ExportPanel'
import LivePreview from '../components/preview/LivePreview'
import Toast from '../components/Toast'
---

<ToolLayout title="Inicio">
  <section slot="tool">
    <h1>NaN Colors</h1>
    <p class="text-muted mt-2">Herramienta de color inteligente</p>

    <div class="mt-8">
      <ColorPicker client:idle />
    </div>

    <div class="mt-6">
      <Tabs client:idle />
    </div>

    <div class="mt-4">
      <PaletteGenerator tab="palettes" client:idle />
    </div>

    <div class="mt-4">
      <SemanticPanel tab="semantic" client:idle />
    </div>

    <div class="mt-4">
      <ContrastPanel tab="contrast" client:idle />
    </div>

    <div class="mt-4">
      <CvdPanel tab="contrast" client:idle />
    </div>

    <div class="mt-4">
      <LivePreview tab="preview" client:idle />
    </div>

    <div class="mt-4">
      <ExportPanel tab="export" client:idle />
    </div>
  </section>

  <section slot="sidebar">
    <p class="text-sm text-muted">Selecciona un color y navega entre las herramientas.</p>
  </section>

  <Toast slot="footer" client:idle />
</ToolLayout>

<script>
import { setHex } from '../stores/color.store'
import { decodePalette } from '../lib/share'

const params = new URLSearchParams(location.search)
const c = params.get('c')
if (c) {
  const decoded = decodePalette(c)
  if (decoded) {
    setHex(decoded)
  }
}
</script>
