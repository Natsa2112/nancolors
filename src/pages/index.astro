---
import ToolLayout from '../layouts/ToolLayout.astro'
import ColorPicker from '../components/color/ColorPicker'
import LivePreview from '../components/preview/LivePreview'
---

<ToolLayout title="Inicio">
  <section slot="tool">
    <h1>NaN Colors</h1>
    <p class="text-muted mt-2">Herramienta de color inteligente</p>

    <div class="mt-8">
      <ColorPicker client:idle />
    </div>

    <div class="mt-8">
      <LivePreview client:idle />
    </div>
  </section>

  <section slot="sidebar">
    <p class="text-sm text-muted">Selecciona un color para ver paletas, contraste y vista previa.</p>
  </section>
</ToolLayout>
