---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Página no encontrada">
  <section class="section" style="text-align: center;">
    <div class="container">
      <h1 style="font-size: clamp(4rem, 10vw, 8rem); line-height: 1;">404</h1>
      <p class="text-muted mt-4">Esta página no existe.</p>
      <a href="/" class="mt-4" style="display: inline-block; padding: var(--space-2) var(--space-6); background: var(--color-primary); color: white; border-radius: var(--radius-md); font-weight: 600; text-decoration: none;">
        Volver al inicio
      </a>
    </div>
  </section>
</BaseLayout>
