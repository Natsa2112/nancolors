<form class="preview-form" onsubmit="return false">
  <label class="preview-form__label" for="preview-email">Correo electrónico</label>
  <input class="preview-form__input" id="preview-email" type="email" placeholder="correo@ejemplo.com" />

  <label class="preview-form__label" for="preview-name">Nombre</label>
  <input class="preview-form__input" id="preview-name" type="text" placeholder="Tu nombre" />

  <button class="preview-btn preview-btn--primary" type="submit">Enviar</button>
</form>
